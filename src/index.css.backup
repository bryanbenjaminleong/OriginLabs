/* Original hero styles (before Option A) */
.hero {
  text-align: center;
  padding-top: 140px;
  padding-bottom: 140px;
  background: var(--gradient-hero);
  position: relative;
}

.hero::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--accent-subtle), transparent);
}
